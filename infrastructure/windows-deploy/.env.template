# =============================================================================
# Loyalty BFF environment configuration template.
#
# Copy this file to apps/bff/.env BEFORE running install.bat:
#   copy infrastructure\windows-deploy\.env.template apps\bff\.env
#
# Then fill in real values below. Lines starting with # are comments.
# Restart the service after any change: stop.bat then start.bat (service mode).
# =============================================================================

# --- Runtime ---
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# Comma-separated list of allowed origins for the admin panel.
CORS_ORIGINS=https://admin.example.com,http://localhost:5173

# --- Database (PostgreSQL) ---
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
# PostgreSQL must be installed separately on the server (or use a remote DB).
DATABASE_URL=postgresql://loyalty:CHANGEME@localhost:5432/loyalty_db?schema=public

# --- Cache (Redis or Memurai) ---
# Native Redis is not officially supported on Windows. Either install Memurai
# (https://www.memurai.com/) which is Redis-compatible, or run Redis in WSL2.
REDIS_URL=redis://localhost:6379

# --- JWT secrets ---
# Generate strong random values: openssl rand -hex 32  (or use any 64-char hex)
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- SMS provider ---
# Primary: 'alfa' or 'beeline'. The other acts as failover.
SMS_PRIMARY_PROVIDER=alfa

# AlfaSMS (current production provider). Uses API key auth.
ALFA_SMS_API_URL=http://api.alfasms.info
ALFA_SMS_API_KEY=

# Legacy login/password — no longer used by the gateway, kept for rollback.
ALFA_SMS_LOGIN=
ALFA_SMS_PASSWORD=

# Beeline SMS (failover, optional).
BEELINE_SMS_API_URL=
BEELINE_SMS_API_KEY=

# --- Push notifications (optional, leave empty if not used) ---
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.loyalty.app
APNS_KEY_PATH=

# --- Loyalty system integration ---
LOYALTY_SYSTEM_API_URL=http://45.84.87.169:5100
LOYALTY_SYSTEM_API_KEY=
LOYALTY_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_HEX

# --- Rate limiting (per phone, sliding window in seconds) ---
RATE_LIMIT_OTP_SEND_MAX=3
RATE_LIMIT_OTP_SEND_WINDOW=600
RATE_LIMIT_OTP_VERIFY_MAX=5
RATE_LIMIT_OTP_VERIFY_WINDOW=600

# --- Push throttling ---
PUSH_MAX_PER_USER_PER_DAY=3
